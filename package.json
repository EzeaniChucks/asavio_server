{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npx tsc",
    "test": "jest",
    "start": "node dist/app.js",
    "dev": "npx tsc && nodemon src/app.ts",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "migrate:generate": "typeorm-ts-node-commonjs migration:generate src/migrations/$npm_config_name -d src/config/database.ts",
    "migrate:run": "typeorm-ts-node-commonjs migration:run -d src/config/database.ts",
    "migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/database.ts",
    "migrate:create": "typeorm-ts-node-commonjs migration:create src/migrations/$npm_config_name",
    "migration:show": "npm run typeorm migration:show -- -d src/config/database.ts",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "seed:reviews": "ts-node src/scripts/seedReviews.ts",
    "seed:vehicle-reviews": "ts-node src/scripts/seedVehicleReviews.ts",
    "seed:new-hosts": "ts-node src/scripts/seedNewHosts.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mailgun.js": "^12.7.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-mailjet": "^6.0.11",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
